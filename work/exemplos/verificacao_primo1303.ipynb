   "source": [
    "\n",
    "num = int(input(\"Digite um numero: \"))\n",
    "\n",
    "isPrimo = True\n",
    "\n",
    "for i in range(2, num):\n",
    "    resto = num % i\n",
    "    if resto == 0:\n",
    "        isPrimo = False\n",
    "        \n",
    "\n",
    "if isPrimo:\n",
    "    print(\"Is primo\")\n",
    "else:\n",
    "    print(\"Not primo\")\n",
    "\n",
    "\n",
    "\n"
   ]
